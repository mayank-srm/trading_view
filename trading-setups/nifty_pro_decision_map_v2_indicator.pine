//@version=6
indicator("NIFTY Pro Decision Map v2.3", overlay=true, max_lines_count=80, max_labels_count=80, max_boxes_count=12)

// Decision-support script only. It does not place trades.

groupSession = "Session and non-repaint"
cashStartHour = input.int(9, "Market open hour", minval=0, maxval=23, group=groupSession, display=display.none)
cashStartMinute = input.int(15, "Market open minute", minval=0, maxval=59, group=groupSession, display=display.none)
cashEndHour = input.int(15, "Market close hour", minval=0, maxval=23, group=groupSession, display=display.none)
cashEndMinute = input.int(30, "Market close minute", minval=0, maxval=59, group=groupSession, display=display.none)
orbMinutes = input.int(15, "Opening range minutes", minval=5, maxval=60, group=groupSession, display=display.none)
noTradeAfterOpenMin = input.int(10, "No trade after open, minutes", minval=0, maxval=60, group=groupSession, display=display.none)
noTradeBeforeCloseMin = input.int(20, "No trade before close, minutes", minval=0, maxval=90, group=groupSession, display=display.none)

groupTrend = "Trend and value"
fastLen = input.int(9, "Fast EMA", minval=1, group=groupTrend, display=display.none)
slowLen = input.int(21, "Slow EMA", minval=1, group=groupTrend, display=display.none)
trendLen1 = input.int(99, "Trend EMA 1", minval=1, group=groupTrend, display=display.none)
trendLen2 = input.int(200, "Trend EMA 2", minval=1, group=groupTrend, display=display.none)
vwapFlatLookback = input.int(5, "VWAP flat lookback", minval=1, maxval=50, group=groupTrend, display=display.none)
vwapFlatAtrMult = input.float(0.05, "VWAP flat ATR multiplier", minval=0.0, step=0.01, group=groupTrend, display=display.none)

groupAdx = "ADX / DMI"
dmiLen = input.int(14, "DMI length", minval=1, group=groupAdx, display=display.none)
adxSmooth = input.int(14, "ADX smoothing", minval=1, group=groupAdx, display=display.none)
adxHardMin = input.float(16.0, "ADX hard no-trade below", minval=1, step=0.5, group=groupAdx, display=display.none)
adxMin = input.float(20.0, "ADX trade minimum", minval=1, step=0.5, group=groupAdx, display=display.none)
strongAdx = input.float(25.0, "Strong ADX", minval=1, step=0.5, group=groupAdx, display=display.none)
adxStableTolerance = input.float(0.3, "ADX stable tolerance", minval=0, step=0.1, group=groupAdx, display=display.none)

groupVol = "Volatility and volume"
atrLen = input.int(14, "ATR length", minval=1, group=groupVol, display=display.none)
atrMaLen = input.int(20, "ATR average length", minval=1, group=groupVol, display=display.none)
atrDeadRatio = input.float(0.65, "ATR dead below avg ratio", minval=0.1, maxval=2.0, step=0.05, group=groupVol, display=display.none)
atrStopMult = input.float(1.0, "ATR stop multiplier", minval=0.1, step=0.1, group=groupVol, display=display.none)
target1Atr = input.float(1.0, "Target 1 ATR", minval=0.1, step=0.1, group=groupVol, display=display.none)
target2Atr = input.float(1.5, "Target 2 ATR", minval=0.1, step=0.1, group=groupVol, display=display.none)
target3Atr = input.float(2.0, "Target 3 ATR", minval=0.1, step=0.1, group=groupVol, display=display.none)
vwapExtensionAtr = input.float(1.5, "No chase beyond ATR from VWAP", minval=0.2, step=0.1, group=groupVol, display=display.none)
volumeSource = input.symbol("", "External volume source, blank = chart", group=groupVol, display=display.none)
volumeMaLen = input.int(20, "Volume MA", minval=1, group=groupVol, display=display.none)
volumeSpikeMult = input.float(1.5, "Volume spike multiplier", minval=0.1, step=0.1, group=groupVol, display=display.none)
allowNoVolumeSignals = input.bool(true, "Allow signals if volume is unavailable", group=groupVol, display=display.none)

groupContext = "One-place trading check"
manualPoc = input.float(0.0, "Manual POC, 0 = off", minval=0, group=groupContext, display=display.none)
manualVah = input.float(0.0, "Manual VAH, 0 = off", minval=0, group=groupContext, display=display.none)
manualVal = input.float(0.0, "Manual VAL, 0 = off", minval=0, group=groupContext, display=display.none)
callOiWall = input.float(0.0, "Major Call OI resistance, 0 = off", minval=0, group=groupContext, display=display.none)
putOiWall = input.float(0.0, "Major Put OI support, 0 = off", minval=0, group=groupContext, display=display.none)
maxPain = input.float(0.0, "Max pain, 0 = off", minval=0, group=groupContext, display=display.none)
oiWallBuffer = input.float(35.0, "OI wall near distance", minval=0, step=5, group=groupContext, display=display.none)
eventMode = input.bool(false, "News/event mode: force NO TRADE", group=groupContext, display=display.none)
expiryMode = input.bool(false, "Expiry day mode", group=groupContext, display=display.none)

groupNews = "One-place trading check"
newsImpactMode = input.bool(true, "Use news impact slider", group=groupNews, display=display.none)
newsImpact = input.int(0, "News impact 0-100", minval=0, maxval=100, group=groupNews, display=display.none)
newsBias = input.string("Neutral", "News bias", options=["Neutral", "Bullish", "Bearish"], group=groupNews, display=display.none)
newsRiskImpact = input.int(40, "Risky above impact", minval=0, maxval=100, group=groupNews, display=display.none)
newsBlockImpact = input.int(70, "NO TRADE above impact", minval=0, maxval=100, group=groupNews, display=display.none)
newsEdgeMax = input.float(5.0, "Max news edge points", minval=0.0, maxval=10.0, step=0.5, group=groupNews, display=display.none)

groupVix = "India VIX"
vixSymbol = input.symbol("NSE:INDIAVIX", "India VIX symbol", group=groupVix, display=display.none)
useVixRisk = input.bool(true, "Use VIX risk filter when available", group=groupVix, display=display.none)
vixLow = input.float(10.0, "Low VIX", minval=0, step=0.5, group=groupVix, display=display.none)
vixHigh = input.float(18.0, "High-risk VIX", minval=0, step=0.5, group=groupVix, display=display.none)
vixSpikePct = input.float(5.0, "VIX spike %", minval=0, step=0.5, group=groupVix, display=display.none)

groupScore = "Score and risk gates"
readyScore = input.int(80, "Ready score", minval=1, maxval=100, group=groupScore, display=display.none)
watchScore = input.int(60, "Internal watch score", minval=1, maxval=100, group=groupScore, display=display.none)
minSideEdge = input.int(35, "Minimum side edge", minval=1, maxval=60, group=groupScore, display=display.none)
minRewardRisk = input.float(1.5, "Minimum reward/risk", minval=0.1, step=0.1, group=groupScore, display=display.none)
minEdgeGap = input.int(20, "Minimum CALL/PUT edge gap", minval=1, maxval=100, group=groupScore, display=display.none)

groupVisual = "Visuals"
showAverages = input.bool(true, "Show VWAP and EMAs", group=groupVisual, display=display.none)
showStructure = input.bool(true, "Show structure levels", group=groupVisual, display=display.none)
showManualLevels = input.bool(true, "Show manual POC/VA/OI levels", group=groupVisual, display=display.none)
showRiskLines = input.bool(true, "Show active stop/targets", group=groupVisual, display=display.none)
showDashboard = input.bool(true, "Show dashboard", group=groupVisual, display=display.none)
showTransitionMarkers = input.bool(true, "Show transition markers", group=groupVisual, display=display.none)
levelBars = input.int(140, "Level line length", minval=30, maxval=500, group=groupVisual, display=display.none)
rightOffset = input.int(8, "Right label offset", minval=1, maxval=50, group=groupVisual, display=display.none)

f_enabled_level(float value) =>
    value > 0 ? value : na

f_nearest_above(float base, float a, float b, float c, float d, float e, float f, float g) =>
    float best = na
    if not na(a) and a > base
        best := a
    if not na(b) and b > base and (na(best) or b < best)
        best := b
    if not na(c) and c > base and (na(best) or c < best)
        best := c
    if not na(d) and d > base and (na(best) or d < best)
        best := d
    if not na(e) and e > base and (na(best) or e < best)
        best := e
    if not na(f) and f > base and (na(best) or f < best)
        best := f
    if not na(g) and g > base and (na(best) or g < best)
        best := g
    best

f_nearest_below(float base, float a, float b, float c, float d, float e, float f, float g) =>
    float best = na
    if not na(a) and a < base
        best := a
    if not na(b) and b < base and (na(best) or b > best)
        best := b
    if not na(c) and c < base and (na(best) or c > best)
        best := c
    if not na(d) and d < base and (na(best) or d > best)
        best := d
    if not na(e) and e < base and (na(best) or e > best)
        best := e
    if not na(f) and f < base and (na(best) or f > best)
        best := f
    if not na(g) and g < base and (na(best) or g > best)
        best := g
    best

f_crossed_above(float level) =>
    not na(level) and close > level and close[1] <= level

f_crossed_below(float level) =>
    not na(level) and close < level and close[1] >= level

f_update_level(line ln, label lb, float price, string name, color col, bool show, bool dotted) =>
    bool visible = show and not na(price) and price > 0
    float y = visible ? price : close
    line.set_xy1(ln, math.max(bar_index - levelBars, 0), y)
    line.set_xy2(ln, bar_index + rightOffset, y)
    line.set_color(ln, visible ? col : color.new(col, 100))
    line.set_width(ln, dotted ? 1 : 2)
    line.set_style(ln, dotted ? line.style_dotted : line.style_solid)
    label.set_xy(lb, bar_index + rightOffset, y)
    label.set_text(lb, visible ? name + " " + str.tostring(price, format.mintick) : "")
    label.set_color(lb, visible ? color.new(col, 8) : color.new(col, 100))
    label.set_textcolor(lb, color.white)
    label.set_size(lb, size.small)

f_rr(float room, float risk) =>
    not na(room) and not na(risk) and risk > 0 ? room / risk : na

f_clamp(float value, float floorVal, float ceilingVal) =>
    na(value) ? floorVal : math.max(floorVal, math.min(ceilingVal, value))

f_reasons(bool c1, string r1, bool c2, string r2, bool c3, string r3, bool c4, string r4, bool c5, string r5, bool c6, string r6, bool c7, string r7, bool c8, string r8, bool c9, string r9, bool c10, string r10, bool c11, string r11, bool c12, string r12, string fallback) =>
    string outText = ""
    int count = 0
    if c1 and count < 3
        outText := outText == "" ? r1 : outText + " + " + r1
        count += 1
    if c2 and count < 3
        outText := outText == "" ? r2 : outText + " + " + r2
        count += 1
    if c3 and count < 3
        outText := outText == "" ? r3 : outText + " + " + r3
        count += 1
    if c4 and count < 3
        outText := outText == "" ? r4 : outText + " + " + r4
        count += 1
    if c5 and count < 3
        outText := outText == "" ? r5 : outText + " + " + r5
        count += 1
    if c6 and count < 3
        outText := outText == "" ? r6 : outText + " + " + r6
        count += 1
    if c7 and count < 3
        outText := outText == "" ? r7 : outText + " + " + r7
        count += 1
    if c8 and count < 3
        outText := outText == "" ? r8 : outText + " + " + r8
        count += 1
    if c9 and count < 3
        outText := outText == "" ? r9 : outText + " + " + r9
        count += 1
    if c10 and count < 3
        outText := outText == "" ? r10 : outText + " + " + r10
        count += 1
    if c11 and count < 3
        outText := outText == "" ? r11 : outText + " + " + r11
        count += 1
    if c12 and count < 3
        outText := outText == "" ? r12 : outText + " + " + r12
        count += 1
    outText == "" ? fallback : outText

sessionStart = timestamp(syminfo.timezone, year(time), month(time), dayofmonth(time), cashStartHour, cashStartMinute)
sessionEnd = timestamp(syminfo.timezone, year(time), month(time), dayofmonth(time), cashEndHour, cashEndMinute)
inCashSession = time >= sessionStart and time < sessionEnd
minutesFromOpen = (time - sessionStart) / 60000.0
minutesToClose = (sessionEnd - time_close) / 60000.0
newCalendarDay = ta.change(time("D")) != 0
var bool wasInCashSession = false
newCashSession = inCashSession and (newCalendarDay or not wasInCashSession)

var float todayOpen = na
var float sessionHigh = na
var float sessionLow = na
var float orbHigh = na
var float orbLow = na

if newCashSession
    todayOpen := open
    sessionHigh := high
    sessionLow := low
    orbHigh := high
    orbLow := low
else if inCashSession
    sessionHigh := math.max(nz(sessionHigh, high), high)
    sessionLow := math.min(nz(sessionLow, low), low)
    if minutesFromOpen < orbMinutes
        orbHigh := math.max(nz(orbHigh, high), high)
        orbLow := math.min(nz(orbLow, low), low)

wasInCashSession := inCashSession

[pdh, pdl, pdc] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)
vixClose = request.security(vixSymbol, "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vixPrev = request.security(vixSymbol, "D", close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
requestedVolume = request.security(volumeSource, timeframe.period, volume, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
sourceVolume = volumeSource == "" ? volume : requestedVolume

emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)
emaTrend1 = ta.ema(close, trendLen1)
emaTrend2 = ta.ema(close, trendLen2)
vwapValue = ta.vwap(hlc3)
[diPlus, diMinus, adx] = ta.dmi(dmiLen, adxSmooth)
atr = ta.atr(atrLen)
atrAvg = ta.sma(atr, atrMaLen)
volAvg = ta.sma(sourceVolume, volumeMaLen)

aboveVwap = close > vwapValue
belowVwap = close < vwapValue
vwapFlat = not na(vwapValue[vwapFlatLookback]) and math.abs(vwapValue - vwapValue[vwapFlatLookback]) <= atr * vwapFlatAtrMult
vwapExtended = not na(atr) and not na(vwapValue) and math.abs(close - vwapValue) > atr * vwapExtensionAtr

emaBull = emaFast > emaSlow and emaFast > emaFast[1] and emaSlow >= emaSlow[1]
emaBear = emaFast < emaSlow and emaFast < emaFast[1] and emaSlow <= emaSlow[1]
priceAboveTrend = close > emaTrend1 or close > emaTrend2
priceBelowTrend = close < emaTrend1 or close < emaTrend2
emaTangled = not na(atr) and math.abs(emaFast - emaSlow) <= atr * 0.15

adxRisingOrStable = adx >= adx[1] - adxStableTolerance
adxTradeOk = adx >= adxMin and adxRisingOrStable
adxHardBlock = not na(adx) and adx < adxHardMin
dmiBull = diPlus > diMinus
dmiBear = diMinus > diPlus

atrDead = not na(atrAvg) and atr < atrAvg * atrDeadRatio
atrValid = not atrDead and not na(atr)
atrExpanding = not na(atrAvg) and atr >= atrAvg

volumeUsable = not na(sourceVolume) and sourceVolume > 0 and not na(volAvg) and volAvg > 0
volumeSpike = volumeUsable and sourceVolume > volAvg * volumeSpikeMult
volumeGate = volumeUsable or (not volumeUsable and allowNoVolumeSignals)

vixUsable = not na(vixClose) and vixClose > 0
vixChangePct = vixUsable and not na(vixPrev) and vixPrev > 0 ? ((vixClose - vixPrev) / vixPrev) * 100.0 : na
vixSpikeRisk = useVixRisk and vixUsable and (vixClose >= vixHigh or (not na(vixChangePct) and vixChangePct >= vixSpikePct))
vixLowRisk = useVixRisk and vixUsable and vixClose <= vixLow and atrDead

poc = f_enabled_level(manualPoc)
vah = f_enabled_level(manualVah)
val = f_enabled_level(manualVal)
callWall = f_enabled_level(callOiWall)
putWall = f_enabled_level(putOiWall)
pain = f_enabled_level(maxPain)

nearCallWall = not na(callWall) and close < callWall and callWall - close <= oiWallBuffer
nearPutWall = not na(putWall) and close > putWall and close - putWall <= oiWallBuffer
callWallBreak = not na(callWall) and f_crossed_above(callWall) and volumeGate
putWallBreak = not na(putWall) and f_crossed_below(putWall) and volumeGate

openBlock = inCashSession and minutesFromOpen >= 0 and minutesFromOpen < noTradeAfterOpenMin
closeBlock = inCashSession and minutesToClose >= 0 and minutesToClose < noTradeBeforeCloseMin
sessionBlock = not inCashSession
expiryBlock = expiryMode and (not adxTradeOk or not volumeSpike)

callBreakLevel = f_crossed_above(vwapValue) or f_crossed_above(pdh) or f_crossed_above(orbHigh) or f_crossed_above(sessionHigh[1]) or f_crossed_above(vah) or callWallBreak
putBreakLevel = f_crossed_below(vwapValue) or f_crossed_below(pdl) or f_crossed_below(orbLow) or f_crossed_below(sessionLow[1]) or f_crossed_below(val) or putWallBreak
callPullbackHold = (low <= vwapValue or low <= emaSlow) and close > open and close > vwapValue and emaBull
putPullbackHold = (high >= vwapValue or high >= emaSlow) and close < open and close < vwapValue and emaBear
callKeyLevel = callBreakLevel or callPullbackHold
putKeyLevel = putBreakLevel or putPullbackHold

callStop = f_nearest_below(close, vwapValue, emaSlow, low, close - atr * atrStopMult, pdc, todayOpen, na)
putStop = f_nearest_above(close, vwapValue, emaSlow, high, close + atr * atrStopMult, pdc, todayOpen, na)
callAtrT1 = close + atr * target1Atr
callAtrT2 = close + atr * target2Atr
callAtrT3 = close + atr * target3Atr
putAtrT1 = close - atr * target1Atr
putAtrT2 = close - atr * target2Atr
putAtrT3 = close - atr * target3Atr
callSessionTarget = not newCashSession ? sessionHigh[1] : na
putSessionTarget = not newCashSession ? sessionLow[1] : na
callTarget = f_nearest_above(close, callSessionTarget, pdh, vah, callWall, pain, poc, callAtrT1)
putTarget = f_nearest_below(close, putSessionTarget, pdl, val, putWall, pain, poc, putAtrT1)
callRisk = not na(callStop) ? close - callStop : na
putRisk = not na(putStop) ? putStop - close : na
callRoom = not na(callTarget) ? callTarget - close : na
putRoom = not na(putTarget) ? close - putTarget : na
callRR = f_rr(callRoom, callRisk)
putRR = f_rr(putRoom, putRisk)
callRROk = not na(callRR) and callRR >= minRewardRisk
putRROk = not na(putRR) and putRR >= minRewardRisk

atrSafe = math.max(nz(atr, 0.0), syminfo.mintick)
diTotal = math.max(nz(diPlus) + nz(diMinus), 1.0)
dmiBullStrength = dmiBull ? f_clamp((diPlus - diMinus) / diTotal, 0.0, 1.0) : 0.0
dmiBearStrength = dmiBear ? f_clamp((diMinus - diPlus) / diTotal, 0.0, 1.0) : 0.0
adxStrength = f_clamp((adx - adxHardMin) / math.max(strongAdx - adxHardMin, 1.0), 0.0, 1.0)
volRatio = volumeUsable ? sourceVolume / volAvg : na

vwapSlopeUp = not vwapFlat and not na(vwapValue[vwapFlatLookback]) and vwapValue > vwapValue[vwapFlatLookback]
vwapSlopeDown = not vwapFlat and not na(vwapValue[vwapFlatLookback]) and vwapValue < vwapValue[vwapFlatLookback]

newsActive = newsImpactMode and newsImpact > 0
newsRisk = newsActive and newsImpact >= newsRiskImpact
newsBlock = newsActive and newsImpact >= newsBlockImpact
newsBullBias = newsActive and newsBias == "Bullish" and newsImpact >= newsRiskImpact
newsBearBias = newsActive and newsBias == "Bearish" and newsImpact >= newsRiskImpact
newsEdgePts = newsActive ? f_clamp(newsImpact / 100.0 * newsEdgeMax, 0.0, newsEdgeMax) : 0.0
newsQualityPenalty = newsActive ? f_clamp(newsImpact / 100.0 * 8.0, 0.0, 8.0) : 0.0
newsCallBlock = newsBlock or newsBearBias
newsPutBlock = newsBlock or newsBullBias

marketAdxPts = adxTradeOk ? 7.0 + adxStrength * 3.0 : adxHardBlock ? 0.0 : adxStrength * 5.0
marketAtrPts = atrValid ? atrExpanding ? 10.0 : 7.0 : 0.0
marketVolumePts = volumeUsable ? volumeSpike ? 10.0 : sourceVolume >= volAvg ? 6.0 : f_clamp(volRatio, 0.0, 1.0) * 4.0 : allowNoVolumeSignals ? 5.0 : 0.0
marketVixPts = not useVixRisk or not vixUsable ? 3.0 : vixSpikeRisk ? 0.0 : vixLowRisk ? 2.0 : 5.0
marketTimePts = sessionBlock or eventMode or openBlock or closeBlock ? 0.0 : 5.0
marketQualityRaw = marketAdxPts + marketAtrPts + marketVolumePts + marketVixPts + marketTimePts - newsQualityPenalty
marketQualityScore = int(math.round(f_clamp(marketQualityRaw, 0.0, 40.0)))

callEdgeRaw = (aboveVwap ? 10.0 : 0.0) + (vwapSlopeUp ? 5.0 : 0.0) + (emaBull ? 10.0 : 0.0) + (priceAboveTrend ? 10.0 : 0.0) + (dmiBull ? 6.0 + dmiBullStrength * 4.0 : 0.0) + (callKeyLevel ? 10.0 : 0.0) + (nearCallWall and not callWallBreak ? 0.0 : 5.0) + (newsBullBias ? newsEdgePts : 0.0)
putEdgeRaw = (belowVwap ? 10.0 : 0.0) + (vwapSlopeDown ? 5.0 : 0.0) + (emaBear ? 10.0 : 0.0) + (priceBelowTrend ? 10.0 : 0.0) + (dmiBear ? 6.0 + dmiBearStrength * 4.0 : 0.0) + (putKeyLevel ? 10.0 : 0.0) + (nearPutWall and not putWallBreak ? 0.0 : 5.0) + (newsBearBias ? newsEdgePts : 0.0)
callEdgeScore = int(math.round(f_clamp(callEdgeRaw, 0.0, 60.0)))
putEdgeScore = int(math.round(f_clamp(putEdgeRaw, 0.0, 60.0)))
callScore = marketQualityScore + callEdgeScore
putScore = marketQualityScore + putEdgeScore
netEdge = callScore - putScore
edgeGap = math.abs(netEdge)

confirmed = barstate.isconfirmed
callDirectionalEligible = aboveVwap and not vwapFlat and not emaTangled and emaBull and priceAboveTrend and dmiBull
putDirectionalEligible = belowVwap and not vwapFlat and not emaTangled and emaBear and priceBelowTrend and dmiBear
callEligible = callDirectionalEligible and callEdgeScore >= minSideEdge
putEligible = putDirectionalEligible and putEdgeScore >= minSideEdge
callEdgeLocked = callScore - putScore >= minEdgeGap and callEligible
putEdgeLocked = putScore - callScore >= minEdgeGap and putEligible
callSignalCandidate = confirmed and callScore >= readyScore and callEdgeLocked and volumeGate and callKeyLevel and not newsCallBlock
putSignalCandidate = confirmed and putScore >= readyScore and putEdgeLocked and volumeGate and putKeyLevel and not newsPutBlock
rrBlock = (callSignalCandidate and not callRROk) or (putSignalCandidate and not putRROk)
oiBlock = (callSignalCandidate and nearCallWall and not callWallBreak) or (putSignalCandidate and nearPutWall and not putWallBreak)
noTradeOverride = sessionBlock or eventMode or openBlock or closeBlock or adxHardBlock or atrDead or expiryBlock or newsBlock or rrBlock or oiBlock
edgeState = noTradeOverride ? "None" : edgeGap < minEdgeGap ? "None" : callEdgeLocked ? "CALL" : putEdgeLocked ? "PUT" : "None"

callSetupRaw = confirmed and edgeState == "CALL" and callScore >= readyScore and callEligible and volumeGate and callKeyLevel and not newsCallBlock
putSetupRaw = confirmed and edgeState == "PUT" and putScore >= readyScore and putEligible and volumeGate and putKeyLevel and not newsPutBlock
callReady = not noTradeOverride and callSetupRaw and callRROk
putReady = not noTradeOverride and putSetupRaw and putRROk
state = noTradeOverride ? "NO TRADE" : callReady ? "CALL READY" : putReady ? "PUT READY" : "WAIT"
stateCode = state == "CALL READY" ? 1 : state == "PUT READY" ? -1 : state == "NO TRADE" ? 2 : 0
stateChanged = confirmed and stateCode != nz(stateCode[1], stateCode)
callReadyAlert = stateChanged and state == "CALL READY"
putReadyAlert = stateChanged and state == "PUT READY"
noTradeAlert = stateChanged and state == "NO TRADE"
callReadyTransition = showTransitionMarkers and callReadyAlert
putReadyTransition = showTransitionMarkers and putReadyAlert
noTradeTransition = noTradeAlert

biasText = aboveVwap and emaBull ? "Bullish" : belowVwap and emaBear ? "Bearish" : "Neutral"
vwapText = aboveVwap ? (vwapFlat ? "Above flat" : "Above") : belowVwap ? (vwapFlat ? "Below flat" : "Below") : "At VWAP"
emaText = emaTangled ? "Tangled" : emaBull ? "9>21 rising" : emaBear ? "9<21 falling" : "Mixed"
adxText = str.tostring(adx, "#.0") + (adx >= strongAdx ? " strong" : adxTradeOk ? " ok" : " weak")
atrText = atrDead ? "Low" : atrExpanding ? "Expanding" : "Tradable"
volText = volumeUsable ? (volumeSpike ? "Spike" : "Weak") : "N/A"
vixText = vixUsable ? str.tostring(vixClose, "#.0") + (vixSpikeRisk ? " risk" : vixClose <= vixLow ? " low" : " ok") : "N/A"
newsStatus = not newsImpactMode ? "off" : newsImpact <= 0 ? "idle" : newsBlock ? "block" : newsRisk ? "risk" : "watch"
newsText = newsImpactMode ? str.tostring(newsImpact) + " " + newsBias + " " + newsStatus : "Manual off"
marketPoor = sessionBlock or eventMode or openBlock or closeBlock or adxHardBlock or atrDead or newsBlock
marketRisky = not marketPoor and (vwapExtended or vixSpikeRisk or vixLowRisk or expiryBlock or newsRisk or rrBlock or oiBlock or vwapFlat or emaTangled or (volumeUsable and not volumeSpike))
marketText = marketPoor ? "Poor" : marketRisky ? "Risky" : "Tradable"

hardBlockText = f_reasons(sessionBlock or eventMode or newsBlock, sessionBlock ? "Session" : newsActive ? "News" : "Event", openBlock, "Open", closeBlock, "Close", adxHardBlock, "ADX", atrDead, "ATR", expiryBlock, "Expiry", rrBlock, "RR", oiBlock, "OI", false, "", false, "", false, "", false, "", "Clear")
riskText = f_reasons(vwapExtended, "Extended", vixSpikeRisk or vixLowRisk, "VIX", volumeUsable and not volumeSpike, "Volume", vwapFlat, "VWAP flat", emaTangled, "EMA", newsRisk, "News", edgeState == "None" and edgeGap < minEdgeGap, "No edge", false, "", false, "", false, "", false, "", false, "", "Clear")
blockText = state == "NO TRADE" ? hardBlockText : riskText

callBlockRaw = f_reasons(not aboveVwap, "Below VWAP", vwapFlat, "VWAP flat", emaTangled, "EMA tangled", not emaBull and not emaTangled, "EMA weak", not dmiBull, "-DI", callEdgeScore < minSideEdge, "Edge weak", not volumeGate, "Weak volume", newsCallBlock, "News", nearCallWall and not callWallBreak, "CALL wall", not callKeyLevel, "No key level", not callRROk, "RR weak", edgeState != "CALL", "No edge", "Inactive")
callBlockText = callBlockRaw == "Inactive" ? "Inactive" : "Blocked - " + callBlockRaw

putBlockRaw = f_reasons(not belowVwap, "Above VWAP", vwapFlat, "VWAP flat", emaTangled, "EMA tangled", not emaBear and not emaTangled, "EMA weak", not dmiBear, "+DI", putEdgeScore < minSideEdge, "Edge weak", not volumeGate, "Weak volume", newsPutBlock, "News", nearPutWall and not putWallBreak, "PUT wall", not putKeyLevel, "No key level", not putRROk, "RR weak", edgeState != "PUT", "No edge", "Inactive")
putBlockText = putBlockRaw == "Inactive" ? "Inactive" : "Blocked - " + putBlockRaw

callDisplay = edgeState == "CALL" and callScore >= watchScore ? str.tostring(callScore) + "/100 RR " + (na(callRR) ? "N/A" : str.tostring(callRR, "#.0")) : edgeState == "PUT" ? "Inactive" : callBlockText
putDisplay = edgeState == "PUT" and putScore >= watchScore ? str.tostring(putScore) + "/100 RR " + (na(putRR) ? "N/A" : str.tostring(putRR, "#.0")) : edgeState == "CALL" ? "Inactive" : putBlockText
callQuick = str.tostring(callScore) + "/100 RR " + (na(callRR) ? "N/A" : str.tostring(callRR, "#.0"))
putQuick = str.tostring(putScore) + "/100 RR " + (na(putRR) ? "N/A" : str.tostring(putRR, "#.0"))
checkText = state == "CALL READY" ? "CALL " + callQuick : state == "PUT READY" ? "PUT " + putQuick : state == "NO TRADE" ? "NO TRADE - " + hardBlockText : edgeState == "None" ? "WAIT - No edge" : "WAIT - " + edgeState + " watch"
checkColor = state == "CALL READY" ? color.lime : state == "PUT READY" ? color.red : state == "NO TRADE" ? color.orange : color.silver

plot(showAverages ? vwapValue : na, "VWAP", color=color.new(color.purple, 0), linewidth=2)
plot(showAverages ? emaFast : na, "EMA 9", color=color.new(color.white, 0), linewidth=1)
plot(showAverages ? emaSlow : na, "EMA 21", color=color.new(color.blue, 0), linewidth=1)
plot(showAverages ? emaTrend1 : na, "EMA 99", color=color.new(color.red, 0), linewidth=1)
plot(showAverages ? emaTrend2 : na, "EMA 200", color=color.new(color.orange, 0), linewidth=2)

plotshape(callReadyTransition, title="CALL READY transition", style=shape.triangleup, location=location.belowbar, color=color.lime, text="CALL READY", textcolor=color.black, size=size.small)
plotshape(putReadyTransition, title="PUT READY transition", style=shape.triangledown, location=location.abovebar, color=color.red, text="PUT READY", textcolor=color.white, size=size.small)

var line pdhLine = line.new(bar_index, close, bar_index, close)
var line pdlLine = line.new(bar_index, close, bar_index, close)
var line pdcLine = line.new(bar_index, close, bar_index, close)
var line openLine = line.new(bar_index, close, bar_index, close)
var line sHighLine = line.new(bar_index, close, bar_index, close)
var line sLowLine = line.new(bar_index, close, bar_index, close)
var line orbHighLine = line.new(bar_index, close, bar_index, close)
var line orbLowLine = line.new(bar_index, close, bar_index, close)
var line pocLine = line.new(bar_index, close, bar_index, close)
var line vahLine = line.new(bar_index, close, bar_index, close)
var line valLine = line.new(bar_index, close, bar_index, close)
var line callWallLine = line.new(bar_index, close, bar_index, close)
var line putWallLine = line.new(bar_index, close, bar_index, close)
var line painLine = line.new(bar_index, close, bar_index, close)
var line stopLine = line.new(bar_index, close, bar_index, close)
var line t1Line = line.new(bar_index, close, bar_index, close)
var line t2Line = line.new(bar_index, close, bar_index, close)
var line t3Line = line.new(bar_index, close, bar_index, close)

var label pdhLabel = label.new(bar_index, close, "")
var label pdlLabel = label.new(bar_index, close, "")
var label pdcLabel = label.new(bar_index, close, "")
var label openLabel = label.new(bar_index, close, "")
var label sHighLabel = label.new(bar_index, close, "")
var label sLowLabel = label.new(bar_index, close, "")
var label orbHighLabel = label.new(bar_index, close, "")
var label orbLowLabel = label.new(bar_index, close, "")
var label pocLabel = label.new(bar_index, close, "")
var label vahLabel = label.new(bar_index, close, "")
var label valLabel = label.new(bar_index, close, "")
var label callWallLabel = label.new(bar_index, close, "")
var label putWallLabel = label.new(bar_index, close, "")
var label painLabel = label.new(bar_index, close, "")
var label stopLabel = label.new(bar_index, close, "")
var label t1Label = label.new(bar_index, close, "")
var label t2Label = label.new(bar_index, close, "")
var label t3Label = label.new(bar_index, close, "")

if barstate.islast
    f_update_level(pdhLine, pdhLabel, pdh, "PDH", color.new(color.lime, 0), showStructure, false)
    f_update_level(pdlLine, pdlLabel, pdl, "PDL", color.new(color.red, 0), showStructure, false)
    f_update_level(pdcLine, pdcLabel, pdc, "PDC", color.new(color.gray, 0), showStructure, true)
    f_update_level(openLine, openLabel, todayOpen, "OPEN", color.new(color.orange, 0), showStructure, true)
    f_update_level(sHighLine, sHighLabel, sessionHigh, "SESSION H", color.new(color.green, 20), showStructure, true)
    f_update_level(sLowLine, sLowLabel, sessionLow, "SESSION L", color.new(color.red, 20), showStructure, true)
    f_update_level(orbHighLine, orbHighLabel, orbHigh, "ORB H", color.new(color.aqua, 0), showStructure, false)
    f_update_level(orbLowLine, orbLowLabel, orbLow, "ORB L", color.new(color.fuchsia, 0), showStructure, false)
    f_update_level(pocLine, pocLabel, poc, "POC", color.new(color.yellow, 0), showManualLevels, true)
    f_update_level(vahLine, vahLabel, vah, "VAH", color.new(color.green, 0), showManualLevels, true)
    f_update_level(valLine, valLabel, val, "VAL", color.new(color.red, 0), showManualLevels, true)
    f_update_level(callWallLine, callWallLabel, callWall, "CALL OI", color.new(color.red, 0), showManualLevels, false)
    f_update_level(putWallLine, putWallLabel, putWall, "PUT OI", color.new(color.green, 0), showManualLevels, false)
    f_update_level(painLine, painLabel, pain, "MAX PAIN", color.new(color.silver, 0), showManualLevels, true)
    activeStop = state == "CALL READY" ? callStop : state == "PUT READY" ? putStop : na
    activeT1 = state == "CALL READY" ? callAtrT1 : state == "PUT READY" ? putAtrT1 : na
    activeT2 = state == "CALL READY" ? callAtrT2 : state == "PUT READY" ? putAtrT2 : na
    activeT3 = state == "CALL READY" ? callAtrT3 : state == "PUT READY" ? putAtrT3 : na
    f_update_level(stopLine, stopLabel, activeStop, "STOP", color.new(color.red, 0), showRiskLines, false)
    f_update_level(t1Line, t1Label, activeT1, "T1", color.new(color.lime, 0), showRiskLines, true)
    f_update_level(t2Line, t2Label, activeT2, "T2", color.new(color.lime, 20), showRiskLines, true)
    f_update_level(t3Line, t3Label, activeT3, "T3", color.new(color.lime, 35), showRiskLines, true)

var table dash = table.new(position.top_right, 2, 15, border_width=1, frame_color=color.new(color.white, 75), border_color=color.new(color.white, 80))

f_cell(int row, string key, string value, color valueColor) =>
    table.cell(dash, 0, row, key, text_color=color.white, bgcolor=color.new(color.black, 20))
    table.cell(dash, 1, row, value, text_color=valueColor, bgcolor=color.new(color.black, 20))

if barstate.islast
    stateColor = state == "CALL READY" ? color.lime : state == "PUT READY" ? color.red : state == "NO TRADE" ? color.orange : color.gray
    if showDashboard
        table.cell(dash, 0, 0, "NIFTY PRO v2.3", text_color=color.white, bgcolor=color.new(color.black, 0))
        table.cell(dash, 1, 0, state, text_color=color.white, bgcolor=color.new(stateColor, 0))
        f_cell(1, "CHECK", checkText, checkColor)
        f_cell(2, "MARKET", marketText, marketText == "Tradable" ? color.lime : marketText == "Risky" ? color.orange : color.red)
        f_cell(3, "EDGE", edgeState, edgeState == "CALL" ? color.lime : edgeState == "PUT" ? color.red : color.silver)
        f_cell(4, "BIAS", biasText, biasText == "Bullish" ? color.lime : biasText == "Bearish" ? color.red : color.silver)
        f_cell(5, "VWAP", vwapText, vwapFlat ? color.orange : aboveVwap ? color.lime : color.red)
        f_cell(6, "EMA", emaText, emaBull ? color.lime : emaBear ? color.red : color.orange)
        f_cell(7, "ADX/DMI", adxText + " / " + (dmiBull ? "+DI" : dmiBear ? "-DI" : "Mixed"), adxTradeOk ? color.lime : color.orange)
        f_cell(8, "ATR", atrText, atrDead ? color.orange : color.lime)
        f_cell(9, "VOLUME", volText, volumeSpike ? color.lime : volumeUsable ? color.orange : color.silver)
        f_cell(10, "VIX", vixText, vixSpikeRisk ? color.red : vixUsable ? color.silver : color.gray)
        f_cell(11, "NEWS", newsText, newsBlock ? color.red : newsRisk ? color.orange : newsActive ? color.silver : color.gray)
        f_cell(12, "BLOCK", blockText, blockText == "Clear" ? color.lime : color.orange)
        f_cell(13, "CALL", callDisplay, edgeState == "CALL" and callScore >= watchScore ? color.lime : color.silver)
        f_cell(14, "PUT", putDisplay, edgeState == "PUT" and putScore >= watchScore ? color.red : color.silver)
    else
        for row = 0 to 14
            table.cell(dash, 0, row, "")
            table.cell(dash, 1, row, "")

alertcondition(callReadyAlert, "NIFTY v2.3 CALL READY", "NIFTY Pro Decision Map v2.3: CALL READY on confirmed candle.")
alertcondition(putReadyAlert, "NIFTY v2.3 PUT READY", "NIFTY Pro Decision Map v2.3: PUT READY on confirmed candle.")
alertcondition(noTradeTransition, "NIFTY v2.3 NO TRADE", "NIFTY Pro Decision Map v2.3: NO TRADE override active.")
alertcondition(stateChanged, "NIFTY v2.3 State changed", "NIFTY Pro Decision Map v2.3: dashboard state changed.")
