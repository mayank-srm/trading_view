//@version=6
indicator("NIFTY Best Call Setup - Decision Map", overlay=true, max_lines_count=60, max_labels_count=60)

// This script is a decision map for the current NIFTY structure. It does not place trades.
// Use it with 30m for bias and 5m/3m for entries.

groupLevels = "Decision levels"
supportNear = input.float(23400, "Immediate support", group=groupLevels)
supportLow = input.float(23280, "Lower support / panic low", group=groupLevels)
breakout1 = input.float(23520, "CALL trigger 1", group=groupLevels)
breakout2 = input.float(23600, "CALL confirmation", group=groupLevels)
trendRes = input.float(23935, "Major trend resistance / TRAMA area", group=groupLevels)
target1 = input.float(23680, "CALL target 1", group=groupLevels)
target2 = input.float(23800, "CALL target 2", group=groupLevels)
putTarget1 = input.float(23320, "PUT target 1", group=groupLevels)
putTarget2 = input.float(23200, "PUT target 2", group=groupLevels)

groupSignal = "Signal filters"
fastLen = input.int(9, "Fast EMA", minval=1, group=groupSignal)
slowLen = input.int(21, "Slow EMA", minval=1, group=groupSignal)
trendLen = input.int(99, "Trend EMA", minval=1, group=groupSignal)
useVwap = input.bool(true, "Require VWAP confirmation intraday", group=groupSignal)
confirmBars = input.int(2, "Bars above/below trigger", minval=1, maxval=5, group=groupSignal)

emaFast = ta.ema(close, fastLen)
emaSlow = ta.ema(close, slowLen)
emaTrend = ta.ema(close, trendLen)
vwapValue = ta.vwap(hlc3)

aboveVwap = not useVwap or close > vwapValue
belowVwap = not useVwap or close < vwapValue
callMomentum = emaFast > emaSlow and close > emaFast and aboveVwap
putMomentum = emaFast < emaSlow and close < emaFast and belowVwap

callTrigger = ta.barssince(close <= breakout1) >= confirmBars - 1 and callMomentum
callConfirm = ta.barssince(close <= breakout2) >= confirmBars - 1 and callMomentum
putBreak = ta.barssince(close >= supportNear) >= confirmBars - 1 and putMomentum
rejectCallZone = high >= breakout1 and close < breakout1 and putMomentum
confirmed = barstate.isconfirmed
earlyCall = callTrigger and not callConfirm
earlyCallAlert = confirmed and earlyCall and not earlyCall[1]
strongCallAlert = confirmed and callConfirm and not callConfirm[1]
putBreakAlert = confirmed and putBreak and not putBreak[1]
rejectCallAlert = confirmed and rejectCallZone and not rejectCallZone[1]

bias =
     close > trendRes ? "BULL TREND" :
     close > breakout2 ? "RECOVERY" :
     close > breakout1 ? "BOUNCE" :
     close > supportNear ? "NO TRADE / WAIT" :
     "BEARISH"

callState =
     callConfirm ? "STRONG CALL: above 23,600" :
     callTrigger ? "EARLY CALL: above 23,520" :
     close > supportNear ? "WAIT: between support and trigger" :
     "NO CALL"

putState =
     putBreak ? "PUT: breakdown below 23,400" :
     rejectCallZone ? "PUT SCALP: rejected 23,520" :
     close < breakout1 ? "PUT FAVORED ON REJECTION" :
     "NO PUT"

lineColorNeutral = color.new(color.gray, 35)
callColor = color.new(color.lime, 0)
putColor = color.new(color.red, 0)
zoneColor = color.new(color.orange, 82)

plot(supportNear, "Immediate support 23,400", color=color.new(color.yellow, 0), linewidth=2)
plot(supportLow, "Lower support 23,280", color=color.new(color.red, 0), linewidth=2)
plot(breakout1, "CALL trigger 23,520", color=color.new(color.aqua, 0), linewidth=2)
plot(breakout2, "CALL confirmation 23,600", color=color.new(color.lime, 0), linewidth=2)
plot(trendRes, "Major resistance 23,935", color=color.new(color.fuchsia, 0), linewidth=2)
plot(target1, "CALL target 23,680", color=color.new(color.green, 35), linewidth=1)
plot(target2, "CALL target 23,800", color=color.new(color.green, 35), linewidth=1)
plot(putTarget1, "PUT target 23,320", color=color.new(color.red, 35), linewidth=1)
plot(putTarget2, "PUT target 23,200", color=color.new(color.red, 35), linewidth=1)

plot(emaFast, "Fast EMA", color=color.new(color.white, 0), linewidth=1)
plot(emaSlow, "Slow EMA", color=color.new(color.blue, 0), linewidth=1)
plot(emaTrend, "Trend EMA", color=color.new(color.red, 0), linewidth=2)
plot(useVwap ? vwapValue : na, "VWAP", color=color.new(color.purple, 0), linewidth=1)

bgcolor(close > supportNear and close < breakout1 ? zoneColor : na, title="No-trade zone")
bgcolor(callConfirm ? color.new(color.lime, 88) : callTrigger ? color.new(color.aqua, 88) : na, title="Call zone")
bgcolor(putBreak or rejectCallZone ? color.new(color.red, 88) : na, title="Put zone")

plotshape(earlyCall, title="Early CALL", style=shape.triangleup, color=callColor, text="CALL?", size=size.tiny, location=location.belowbar)
plotshape(callConfirm, title="Strong CALL", style=shape.triangleup, color=callColor, text="CALL", size=size.small, location=location.belowbar)
plotshape(putBreak, title="PUT breakdown", style=shape.triangledown, color=putColor, text="PUT", size=size.small, location=location.abovebar)
plotshape(rejectCallZone, title="PUT rejection", style=shape.triangledown, color=color.orange, text="REJ", size=size.tiny, location=location.abovebar)

var table dash = table.new(position.top_right, 2, 7, border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "NIFTY SETUP", bgcolor=color.new(color.black, 0), text_color=color.white)
    table.cell(dash, 1, 0, bias, bgcolor=close > breakout1 ? color.new(color.green, 25) : color.new(color.red, 25), text_color=color.white)
    table.cell(dash, 0, 1, "CALL plan", text_color=color.white)
    table.cell(dash, 1, 1, callState, text_color=color.white)
    table.cell(dash, 0, 2, "PUT plan", text_color=color.white)
    table.cell(dash, 1, 2, putState, text_color=color.white)
    table.cell(dash, 0, 3, "No trade", text_color=color.white)
    table.cell(dash, 1, 3, "23,400 - 23,520", text_color=color.orange)
    table.cell(dash, 0, 4, "CALL invalid", text_color=color.white)
    table.cell(dash, 1, 4, "Close back < 23,520", text_color=color.red)
    table.cell(dash, 0, 5, "PUT invalid", text_color=color.white)
    table.cell(dash, 1, 5, "Close back > 23,520/23,600", text_color=color.lime)
    table.cell(dash, 0, 6, "Best TF", text_color=color.white)
    table.cell(dash, 1, 6, "30m bias, 5m trigger", text_color=color.aqua)

alertcondition(earlyCallAlert, "NIFTY early CALL", "NIFTY is holding above CALL trigger with momentum.")
alertcondition(strongCallAlert, "NIFTY strong CALL", "NIFTY confirmed above CALL confirmation level.")
alertcondition(putBreakAlert, "NIFTY PUT breakdown", "NIFTY broke below immediate support with bearish momentum.")
alertcondition(rejectCallAlert, "NIFTY rejection PUT scalp", "NIFTY rejected CALL trigger zone with bearish momentum.")
